{
  "name": "omp-wechat",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "bun build --compile --outfile=omp-wechat --external omp-legacy-pi-modules src/main.ts",
    "login": "bun run src/main.ts login",
    "run": "bun run src/main.ts run",
    "install": "bun run src/main.ts install",
    "uninstall": "bun run src/main.ts uninstall",
    "pair": "bun run src/main.ts pair",
    "status": "bun run src/main.ts status",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oh-my-pi/pi-coding-agent": "latest",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
