# OMP working directory (tools operate here)
OMP_WECHAT_CWD=/Users/you/Desktop/Work

# Model (provider/model format, empty = OMP default)
OMP_MODEL=

# Allowed tools (comma-separated)
OMP_WECHAT_TOOLS=read,grep,glob,write,edit,bash

# Session pool cap
OMP_WECHAT_MAX_SESSIONS=50

# Access policy: pairing | allowlist | disabled
OMP_WECHAT_DM_POLICY=pairing
